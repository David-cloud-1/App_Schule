# Supabase — Required
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# WARNING: Never expose this key in the browser. Server-side only (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Optional: Protects the one-time badge migration endpoint (POST /api/badges/migrate)
# Set to any random secret string. If unset, the endpoint is open.
BADGE_MIGRATE_SECRET=your_random_secret_here

# Note: NEXT_PUBLIC_ vars are safe to expose in the browser.
# The anon key is protected by Supabase RLS policies.

# Future variables (add as features are built):
# STRIPE_SECRET_KEY=sk_...
# SMTP_HOST=smtp.sendgrid.net
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
